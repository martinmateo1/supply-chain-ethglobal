      owner = operator
      lotId = "lot-cert-b"
      commodity = Coffee
      quantity = Quantity 1000.0 "tons"
      certifications = [NonGMO]
      quality = GradeA
      originIdentifier = None
      provenance = []

  submitMustFail operator do
    exerciseCmd lotA CombineLots with
