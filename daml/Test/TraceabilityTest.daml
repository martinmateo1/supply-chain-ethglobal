module Test.TraceabilityTest where

import Commodity.LotPosition
import Commodity.Types
import DA.List ((!!))
import Daml.Script

-- Happy path: create lot → initiate transfer → accept.
testCustodyHappyPath : Script ()
testCustodyHappyPath = script do
  sender <- allocateParty "Sender"
  receiver <- allocateParty "Receiver"

  lotCid <- submit sender do
    createCmd LotPosition with
      owner = sender
      lotId = "lot-happy-1"
      commodity = Coffee
      quantity = Quantity 100.0 "tons"
      certifications = [NonGMO, DeforestationFree]
      quality = GradeA
      originIdentifier = Some "origin-huila-001"
      provenance = []

  (transferCid, remainder) <- submit sender do
    exerciseCmd lotCid InitiateTransfer with
      receiver
      transferId = "t-happy-1"
      transferAmount = 40.0
      evidenceHashes = ["0xabc123"]

  case remainder of
    Some remCid -> do
      remOpt <- queryContractId sender remCid
      case remOpt of
        Some rem -> assertMsg "Remainder quantity wrong" (rem.quantity.amount == 60.0)
        None -> abort "Remainder lot not found"
    None -> abort "Expected remainder lot after partial transfer"

  receiverLotCid <- submit receiver do
    exerciseCmd transferCid AcceptTransfer with occurredAt = ""

  receiverLotOpt <- queryContractId receiver receiverLotCid
  case receiverLotOpt of
    Some receiverLot -> do
      assertMsg "Receiver lot quantity wrong" (receiverLot.quantity.amount == 40.0)
      assertMsg "Receiver lot commodity wrong" (receiverLot.commodity == Coffee)
      assertMsg "Provenance not preserved" (receiverLot.originIdentifier == Some "origin-huila-001")
      assertMsg "Provenance chain should grow on accept" (length receiverLot.provenance == 1)
      let hop = receiverLot.provenance !! 0
      assertMsg "Evidence hash should survive accept" (elem "0xabc123" hop.evidenceHashes)
    None -> abort "Receiver lot not found after accept"

  pure ()

-- Negative: the source lot is consumed on initiate, so it cannot be
-- re-spent (anti-double-spend). The remainder is a *separate* valid position.
testDoubleSpendBlocked : Script ()
testDoubleSpendBlocked = script do
  sender <- allocateParty "Sender"
  receiver <- allocateParty "Receiver"

  lotCid <- submit sender do
    createCmd LotPosition with
      owner = sender
      lotId = "lot-ds-1"
      commodity = Cacao
      quantity = Quantity 50.0 "tons"
      certifications = [DeforestationFree]
      quality = GradeB
      originIdentifier = None
      provenance = []

  (transferCid, remainder) <- submit sender do
    exerciseCmd lotCid InitiateTransfer with
      receiver
      transferId = "t-ds-1"
      transferAmount = 30.0
      evidenceHashes = []

  -- Conservation: reserved 30 + remainder 20 == original 50.
  remCid <- case remainder of
    Some cid -> pure cid
    None -> abort "Expected remainder lot"

  remOpt <- queryContractId sender remCid
  case remOpt of
    Some rem -> assertMsg "Remainder must be 20" (rem.quantity.amount == 20.0)
    None -> abort "Remainder lot not found"

  -- The remainder is a fresh, spendable position: spending it up to its
  -- amount succeeds (proves the failure below is double-spend, not a generic
  -- "amount too large" rejection).
  (_, _) <- submit sender do
    exerciseCmd remCid InitiateTransfer with
      receiver
      transferId = "t-ds-remainder"
      transferAmount = 20.0
      evidenceHashes = []

  -- Double-spend: the ORIGINAL lot was archived on the first initiate, so a
  -- second initiate on it must fail because the contract no longer exists.
  submitMustFail sender do
    exerciseCmd lotCid InitiateTransfer with
      receiver
      transferId = "t-ds-orphan"
      transferAmount = 10.0
      evidenceHashes = []

  pendingOpt <- queryContractId sender transferCid
  case pendingOpt of
    Some pending -> assertMsg "Transfer should still be pending" (pending.status == Pending)
    None -> abort "Pending transfer not found"

  pure ()

-- Guard: a transfer cannot be accepted twice (consumed on accept).
testCannotAcceptTwice : Script ()
testCannotAcceptTwice = script do
  sender <- allocateParty "Sender"
  receiver <- allocateParty "Receiver"

  lotCid <- submit sender do
    createCmd LotPosition with
      owner = sender
      lotId = "lot-accept2"
      commodity = Coffee
      quantity = Quantity 10.0 "tons"
      certifications = [NonGMO]
      quality = GradeA
      originIdentifier = None
      provenance = []

  (transferCid, _) <- submit sender do
    exerciseCmd lotCid InitiateTransfer with
      receiver
      transferId = "t-accept2"
      transferAmount = 10.0
      evidenceHashes = []

  _ <- submit receiver do
    exerciseCmd transferCid AcceptTransfer with occurredAt = ""

  submitMustFail receiver do
    exerciseCmd transferCid AcceptTransfer with occurredAt = ""

  pure ()

-- Guard: a rejected transfer cannot then be accepted (consumed on reject).
testCannotAcceptAfterReject : Script ()
testCannotAcceptAfterReject = script do
  sender <- allocateParty "Sender"
  receiver <- allocateParty "Receiver"

  lotCid <- submit sender do
    createCmd LotPosition with
      owner = sender
      lotId = "lot-rej-accept"
      commodity = Coffee
      quantity = Quantity 10.0 "tons"
      certifications = [NonGMO]
      quality = GradeA
      originIdentifier = None
      provenance = []

  (transferCid, _) <- submit sender do
    exerciseCmd lotCid InitiateTransfer with
      receiver
      transferId = "t-rej-accept"
      transferAmount = 10.0
      evidenceHashes = []

  _ <- submit receiver do
    exerciseCmd transferCid RejectTransfer with occurredAt = ""

  submitMustFail receiver do
    exerciseCmd transferCid AcceptTransfer with occurredAt = ""

  pure ()

-- Guard: transfer amount must be strictly positive.
testTransferAmountMustBePositive : Script ()
testTransferAmountMustBePositive = script do
  sender <- allocateParty "Sender"
  receiver <- allocateParty "Receiver"

  lotCid <- submit sender do
    createCmd LotPosition with
      owner = sender
      lotId = "lot-pos-1"
      commodity = Coffee
      quantity = Quantity 10.0 "tons"
      certifications = [NonGMO]
      quality = GradeA
      originIdentifier = None
      provenance = []

  submitMustFail sender do
    exerciseCmd lotCid InitiateTransfer with
      receiver
      transferId = "t-pos-zero"
      transferAmount = 0.0
      evidenceHashes = []

  pure ()

-- Reject releases reserved quantity back to sender.
testRejectReleasesQuantity : Script ()
testRejectReleasesQuantity = script do
  sender <- allocateParty "Sender"
  receiver <- allocateParty "Receiver"

  lotCid <- submit sender do
    createCmd LotPosition with
      owner = sender
      lotId = "lot-reject-1"
      commodity = Coffee
      quantity = Quantity 25.0 "tons"
      certifications = [NonGMO]
      quality = GradeC
      originIdentifier = Some "origin-reject"
      provenance = []

  (transferCid, _) <- submit sender do
    exerciseCmd lotCid InitiateTransfer with
      receiver
      transferId = "t-reject-1"
      transferAmount = 25.0
      evidenceHashes = ["0xreject"]

  returnedCid <- submit receiver do
    exerciseCmd transferCid RejectTransfer with occurredAt = ""

  returnedOpt <- queryContractId sender returnedCid
  case returnedOpt of
    Some returned -> do
      assertMsg "Rejected quantity not returned to sender" (returned.quantity.amount == 25.0)
      assertMsg "Returned lot owner wrong" (returned.owner == sender)
    None -> abort "Returned lot not found after reject"

  pure ()

-- Combine: two compatible lots merge into one position; quantity is the exact
-- sum and both sources are consumed.
testCombineCompatible : Script ()
testCombineCompatible = script do
  operator <- allocateParty "StorageOperator"

  lotA <- submit operator do
    createCmd LotPosition with
      owner = operator
      lotId = "lot-combine-a"
      commodity = Coffee
      quantity = Quantity 1000.0 "tons"
      certifications = [NonGMO, DeforestationFree]
      quality = GradeA
      originIdentifier = Some "origin-a"
      provenance = []

  lotB <- submit operator do
    createCmd LotPosition with
      owner = operator
      lotId = "lot-combine-b"
      commodity = Coffee
      quantity = Quantity 2500.0 "tons"
      -- Reversed order proves set comparison is order-independent.
      certifications = [DeforestationFree, NonGMO]
      quality = GradeA
      originIdentifier = Some "origin-b"
      provenance = []

  combinedCid <- submit operator do
    exerciseCmd lotA CombineLots with
      otherLotCid = lotB
      combinedLotId = "lot-combine-ab"

  combinedOpt <- queryContractId operator combinedCid
  case combinedOpt of
    Some combined -> do
      assertMsg "Combined quantity must equal sum" (combined.quantity.amount == 3500.0)
      assertMsg "Combined commodity wrong" (combined.commodity == Coffee)
      assertMsg "Combined certs wrong" (sameCertSet combined.certifications [NonGMO, DeforestationFree])
    None -> abort "Combined lot not found"

  -- Both sources are consumed (anti-double-spend).
  aOpt <- queryContractId operator lotA
  bOpt <- queryContractId operator lotB
  assertMsg "Source A should be archived" (aOpt == None)
  assertMsg "Source B should be archived" (bOpt == None)

  pure ()

-- Combine guard: different commodities cannot combine.
testCombineIncompatibleCommodity : Script ()
testCombineIncompatibleCommodity = script do
  operator <- allocateParty "StorageOperator"

  lotA <- submit operator do
    createCmd LotPosition with
      owner = operator
      lotId = "lot-bad-a"
      commodity = Coffee
      quantity = Quantity 1000.0 "tons"
      certifications = [NonGMO]
      quality = GradeA
      originIdentifier = None
      provenance = []

  lotB <- submit operator do
    createCmd LotPosition with
      owner = operator
      lotId = "lot-bad-b"
      commodity = Cacao
      quantity = Quantity 1000.0 "tons"
      certifications = [NonGMO]
      quality = GradeA
      originIdentifier = None
      provenance = []

  submitMustFail operator do
    exerciseCmd lotA CombineLots with
      otherLotCid = lotB
      combinedLotId = "lot-bad-ab"

  pure ()

