      combinedLotId = "lot-cert-ab"

  pure ()

-- Multi-leg: a full custody chain across distinct owners
-- (silo → rail → origin-port → ship → destination-port) must preserve
-- commodity, certifications, provenance, and quantity at every hop.
testMultiLegRoute : Script ()
testMultiLegRoute = script do
  silo <- allocateParty "Silo"
  rail <- allocateParty "Rail"
  originPort <- allocateParty "OriginPort"
  ship <- allocateParty "Ship"
  destPort <- allocateParty "DestinationPort"

  -- One leg: full transfer (no remainder), accept, assert preservation.
  let
    leg : Party -> ContractId LotPosition -> Party -> Text -> Script (ContractId LotPosition)
    leg sender lotCid receiver transferId = do
      (transferCid, remainder) <- submit sender do
        exerciseCmd lotCid InitiateTransfer with
          receiver
          transferId
          transferAmount = 9000.0
          evidenceHashes = []

      assertMsg "Full transfer should leave no remainder" (remainder == None)

      receiverLotCid <- submit receiver do
        exerciseCmd transferCid AcceptTransfer with occurredAt = ""

      receiverLotOpt <- queryContractId receiver receiverLotCid
      case receiverLotOpt of
        Some receiverLot -> do
          assertMsg "Quantity not conserved across leg" (receiverLot.quantity.amount == 9000.0)
          assertMsg "Commodity not preserved across leg" (receiverLot.commodity == Coffee)
          assertMsg "Certifications not preserved across leg"
            (receiverLot.certifications == [NonGMO, DeforestationFree])
          assertMsg "Provenance not preserved across leg"
            (receiverLot.originIdentifier == Some "origin-huila-001")
          assertMsg "Provenance chain should grow each leg"
            (length receiverLot.provenance >= 1)
        None -> abort "Receiver lot not found after accept"

      pure receiverLotCid

  -- Origin custody held by the silo operator.
  lot0 <- submit silo do
    createCmd LotPosition with
      owner = silo
      lotId = "lot-route-0"
      commodity = Coffee
      quantity = Quantity 9000.0 "tons"
      certifications = [NonGMO, DeforestationFree]
      quality = GradeA
      originIdentifier = Some "origin-huila-001"
      provenance = []

  railLot <- leg silo lot0 rail "t-route-rail"
  portLot <- leg rail railLot originPort "t-route-origin-port"
  shipLot <- leg originPort portLot ship "t-route-ship"
  _ <- leg ship shipLot destPort "t-route-destination-port"

  pure ()
