module Commodity.CustodyTransfer where

import Commodity.Types

data TransferStatus = Pending | Completed | Rejected
  deriving (Eq, Show)

-- CustodyTransfer records an evidence-backed custody movement between parties.
-- InitiateTransfer / AcceptTransfer choices arrive in Epic 2.

template CustodyTransfer
  with
    sender : Party
    receiver : Party
    quantity : Quantity
    status : TransferStatus
  where
    signatory sender
    observer receiver
